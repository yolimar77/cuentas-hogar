@page "/configuracion"
@using HomeAccounts.Models
@using HomeAccounts.Services
@inject LocalDbService Db
@inject DriveService Drive
@inject SyncService Sync
@inject IJSRuntime JS
@implements IDisposable

<div class="container-sm py-3">
    <h5 class="mb-3">Configuración</h5>

    <!-- Google Drive -->
    <div class="card mb-3">
        <div class="card-body">
            <h6 class="card-title">Google Drive</h6>
            @if (Drive.Conectado)
            {
                <p class="text-success small mb-1">✅ Conectado con Google Drive</p>
                <p class="text-muted small mb-2">
                    Última sync: @(Sync.UltimaSincronizacion?.ToString("dd/MM HH:mm") ?? "nunca")
                </p>
                @if (Sync.UltimoError is not null)
                {
                    <p class="text-danger small mb-2">⚠️ @Sync.UltimoError</p>
                }
                @if (Sync.UltimoDetalle is not null)
                {
                    <p class="text-muted small mb-2">@Sync.UltimoDetalle</p>
                }
                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-outline-primary btn-sm" @onclick="Sincronizar" disabled="@Sync.SincronizandoAhora">
                        @(Sync.SincronizandoAhora ? "Sincronizando..." : "Sincronizar ahora")
                    </button>
                    <button class="btn btn-outline-danger btn-sm" @onclick="Desconectar">Desconectar</button>
                </div>
            }
            else
            {
                <p class="text-muted small mb-2">No conectado. Conéctate para sincronizar entre dispositivos.</p>
                <button class="btn btn-outline-primary btn-sm" @onclick="Conectar">Conectar con Google</button>
            }
        </div>
    </div>

    <!-- Acceso compartido (familia) -->
    <div class="card mb-3">
        <div class="card-body">
            <h6 class="card-title">Acceso compartido</h6>

            @if (Drive.Conectado && Drive.FolderId != null)
            {
                <p class="text-muted small mb-1">Tu código de familia (compártelo con tu pareja):</p>
                <div class="input-group input-group-sm mb-3">
                    <input class="form-control font-monospace" readonly value="@Drive.FolderId" />
                    <button class="btn btn-outline-secondary" @onclick="CopiarCodigo">Copiar</button>
                </div>

                <p class="text-muted small mb-1">Dar acceso a otro correo de Google:</p>
                <div class="input-group input-group-sm mb-3">
                    <input class="form-control" @bind="_emailCompartir" placeholder="correo@gmail.com" />
                    <button class="btn btn-outline-primary" @onclick="CompartirCarpeta"
                            disabled="@_compartiendoAhora">
                        @(_compartiendoAhora ? "..." : "Compartir")
                    </button>
                </div>
                @if (_mensajeCompartir is not null)
                {
                    <p class="small @(_errorCompartir ? "text-danger" : "text-success") mb-2">@_mensajeCompartir</p>
                }
            }

            <p class="text-muted small mb-1">¿Tienes el código de otra cuenta? Úsalo aquí:</p>
            <div class="input-group input-group-sm mb-2">
                <input class="form-control font-monospace" @bind="_codigoExterno" placeholder="Pega el código de familia" />
                <button class="btn btn-outline-secondary" @onclick="UsarCodigoExterno">Usar</button>
            </div>
            @if (_mensajeCodigo is not null)
            {
                <p class="small text-success mb-2">@_mensajeCodigo</p>
            }

            @if (Drive.Conectado)
            {
                <hr class="my-2" />
                <p class="text-muted small mb-1">Si los datos no coinciden entre dispositivos, restablece la sincronización:</p>
                <button class="btn btn-outline-warning btn-sm" @onclick="RestablecerSync"
                        disabled="@_restableciendo">
                    @(_restableciendo ? "Restableciendo..." : "Restablecer sincronización")
                </button>
            }
        </div>
    </div>

    <!-- Cuentas -->
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="card-title mb-0">Cuentas</h6>
                <button class="btn btn-outline-primary btn-sm" @onclick="AbrirNuevaCuenta">+ Añadir</button>
            </div>
            @foreach (var cuenta in _cuentas)
            {
                <div class="d-flex justify-content-between align-items-center py-1 border-bottom">
                    <span>@cuenta.Nombre</span>
                    <button class="btn btn-link btn-sm text-danger p-0" @onclick="() => EliminarCuenta(cuenta.Id)">🗑</button>
                </div>
            }
        </div>
    </div>

    <!-- Categorías -->
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="card-title mb-0">Categorías</h6>
                <button class="btn btn-outline-primary btn-sm" @onclick="AbrirNuevaCategoria">+ Añadir</button>
            </div>
            @foreach (var cat in _categorias)
            {
                <div class="d-flex justify-content-between align-items-center py-1 border-bottom">
                    <span>@cat.Icono @cat.Nombre <small class="text-muted">(@(cat.Tipo == TipoMovimiento.Ingreso ? "ingreso" : "gasto"))</small></span>
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-link btn-sm text-secondary p-0" @onclick="() => AbrirEditarCategoria(cat)"><i class="ph-bold ph-pencil-simple" style="font-size:1.1rem"></i></button>
                        <button class="btn btn-link btn-sm text-danger p-0" @onclick="() => EliminarCategoria(cat.Id)">🗑</button>
                    </div>
                </div>
            }
        </div>
    </div>

</div>

@if (_mostrarCuenta)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header"><h6 class="modal-title">Nueva cuenta</h6><button class="btn-close" @onclick="() => _mostrarCuenta = false"></button></div>
                <div class="modal-body">
                    <input class="form-control mb-2" @bind="_nuevaCuenta.Nombre" placeholder="Nombre de la cuenta" />
                    <input class="form-control" type="number" step="0.01" @bind="_nuevaCuenta.SaldoInicial" placeholder="Saldo inicial (€)" />
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="() => _mostrarCuenta = false">Cancelar</button>
                    <button class="btn btn-primary btn-sm" @onclick="GuardarCuenta">Guardar</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_mostrarCategoria)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header"><h6 class="modal-title">@(_esEdicionCategoria ? "Editar categoría" : "Nueva categoría")</h6><button class="btn-close" @onclick="() => _mostrarCategoria = false"></button></div>
                <div class="modal-body">
                    <div class="mb-2">
                        <label class="form-label small">Tipo</label>
                        <div class="btn-group w-100">
                            <button class="btn @(_nuevaCategoria.Tipo == TipoMovimiento.Gasto ? "btn-danger" : "btn-outline-danger")"
                                    @onclick="() => _nuevaCategoria.Tipo = TipoMovimiento.Gasto">Gasto</button>
                            <button class="btn @(_nuevaCategoria.Tipo == TipoMovimiento.Ingreso ? "btn-success" : "btn-outline-success")"
                                    @onclick="() => _nuevaCategoria.Tipo = TipoMovimiento.Ingreso">Ingreso</button>
                        </div>
                    </div>
                    <input class="form-control mb-2" @bind="_nuevaCategoria.Nombre" @bind:event="oninput" placeholder="Nombre" />
                    <input class="form-control mb-2" @bind="_nuevaCategoria.Icono" placeholder="Emoji (ej: 🛒)" />
                    @if (_nuevaCategoria.Tipo == TipoMovimiento.Gasto)
                    {
                        <div class="mb-2">
                            <label class="form-label small">Mínimo mensual (€) <span class="text-muted">(opcional)</span></label>
                            <input class="form-control" type="number" step="0.01" min="0"
                                   value="@_nuevaCategoria.MinimoMensual"
                                   @onchange="@(e => _nuevaCategoria.MinimoMensual = decimal.TryParse(e.Value?.ToString(), out var v) && v > 0 ? v : null)" />
                        </div>
                    }
                    @if (_errorCategoria is not null)
                    {
                        <p class="text-danger small mt-2 mb-0">@_errorCategoria</p>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="() => _mostrarCategoria = false">Cancelar</button>
                    <button class="btn btn-primary btn-sm" @onclick="GuardarCategoria">Guardar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Cuenta> _cuentas = [];
    private List<Categoria> _categorias = [];
    private bool _mostrarCuenta = false;
    private bool _mostrarCategoria = false;
    private Cuenta _nuevaCuenta = new();
    private Categoria _nuevaCategoria = new();
    private bool _esEdicionCategoria = false;
    private string? _errorCategoria;
    private string _emailCompartir = "";
    private string _codigoExterno = "";
    private bool _compartiendoAhora = false;
    private bool _restableciendo = false;
    private string? _mensajeCompartir;
    private bool _errorCompartir;
    private string? _mensajeCodigo;

    protected override async Task OnInitializedAsync()
    {
        Drive.OnEstadoCambiado += OnDriveEstadoCambiado;
        Sync.OnSyncCompletado += OnSyncCompletado;
        await Cargar();
    }

    private void OnDriveEstadoCambiado() => InvokeAsync(StateHasChanged);
    private async Task OnSyncCompletado()
    {
        await Cargar();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Drive.OnEstadoCambiado -= OnDriveEstadoCambiado;
        Sync.OnSyncCompletado -= OnSyncCompletado;
    }

    private async Task Cargar()
    {
        _cuentas = (await Db.ObtenerCuentasAsync())
            .GroupBy(c => c.Nombre)
            .Select(g => g.FirstOrDefault(x => x.Id.StartsWith("def-")) ?? g.First())
            .ToList();
        _categorias = (await Db.ObtenerCategoriasAsync())
            .GroupBy(c => (c.Nombre, c.Tipo))
            .Select(g => g.FirstOrDefault(x => x.Id.StartsWith("def-")) ?? g.First())
            .ToList();
    }

    private void AbrirNuevaCuenta() { _nuevaCuenta = new Cuenta(); _mostrarCuenta = true; }

    private void AbrirNuevaCategoria()
    {
        _nuevaCategoria = new Categoria();
        _esEdicionCategoria = false;
        _errorCategoria = null;
        _mostrarCategoria = true;
    }

    private void AbrirEditarCategoria(Categoria cat)
    {
        _nuevaCategoria = new Categoria
        {
            Id            = cat.Id,
            Nombre        = cat.Nombre,
            Tipo          = cat.Tipo,
            Icono         = cat.Icono,
            MinimoMensual = cat.MinimoMensual,
            ModificadoEn  = DateTime.UtcNow
        };
        _esEdicionCategoria = true;
        _errorCategoria = null;
        _mostrarCategoria = true;
    }

    private async Task GuardarCuenta()
    {
        if (string.IsNullOrWhiteSpace(_nuevaCuenta.Nombre)) return;
        _nuevaCuenta.ModificadoEn = DateTime.UtcNow;
        await Db.GuardarCuentaAsync(_nuevaCuenta);
        await Cargar();
        _mostrarCuenta = false;
        _ = Sync.SincronizarAsync();
    }

    private async Task GuardarCategoria()
    {
        _errorCategoria = null;
        if (string.IsNullOrWhiteSpace(_nuevaCategoria.Nombre))
        {
            _errorCategoria = "El nombre es obligatorio.";
            return;
        }
        try
        {
            _nuevaCategoria.ModificadoEn = DateTime.UtcNow;
            await Db.GuardarCategoriaAsync(_nuevaCategoria);
            await Cargar();
            _mostrarCategoria = false;
            _ = Sync.SincronizarAsync();
        }
        catch (Exception ex)
        {
            _errorCategoria = $"Error al guardar: {ex.Message}";
        }
    }

    private async Task EliminarCuenta(string id)
    {
        var target = (await Db.ObtenerCuentasAsync()).FirstOrDefault(c => c.Id == id);
        if (target is not null)
        {
            var todas = await Db.ObtenerCuentasAsync();
            foreach (var dup in todas.Where(c => c.Nombre == target.Nombre))
                await Db.EliminarCuentaAsync(dup.Id);
        }
        else
        {
            await Db.EliminarCuentaAsync(id);
        }
        await Cargar();
        _ = Sync.SincronizarAsync();
    }

    private async Task EliminarCategoria(string id)
    {
        // Eliminar también duplicados con el mismo nombre+tipo para limpiar la BD
        var target = (await Db.ObtenerCategoriasAsync()).FirstOrDefault(c => c.Id == id);
        if (target is not null)
        {
            var todas = await Db.ObtenerCategoriasAsync();
            var duplicados = todas.Where(c => c.Nombre == target.Nombre && c.Tipo == target.Tipo).ToList();
            foreach (var dup in duplicados)
                await Db.EliminarCategoriaAsync(dup.Id);
        }
        else
        {
            await Db.EliminarCategoriaAsync(id);
        }
        await Cargar();
        _ = Sync.SincronizarAsync();
    }

    private async Task Conectar()
    {
        await Drive.ConectarAsync();
        if (Drive.Conectado)
        {
            await Drive.ObtenerOCrearCarpetaAsync();
            await Sync.SincronizarAsync();
        }
    }

    private async Task Desconectar() => await Drive.DesconectarAsync();
    private async Task Sincronizar() => await Sync.SincronizarAsync();

    private async Task CopiarCodigo()
    {
        if (Drive.FolderId is not null)
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", Drive.FolderId);
    }

    private async Task CompartirCarpeta()
    {
        if (string.IsNullOrWhiteSpace(_emailCompartir)) return;
        _compartiendoAhora = true;
        _mensajeCompartir = null;
        try
        {
            await Drive.CompartirConAsync(_emailCompartir.Trim());
            _mensajeCompartir = $"✅ Carpeta compartida con {_emailCompartir.Trim()}";
            _errorCompartir = false;
            _emailCompartir = "";
        }
        catch (Exception ex)
        {
            _mensajeCompartir = $"Error: {ex.Message}";
            _errorCompartir = true;
        }
        finally { _compartiendoAhora = false; }
    }

    private async Task UsarCodigoExterno()
    {
        if (string.IsNullOrWhiteSpace(_codigoExterno)) return;
        await Drive.EstablecerCarpetaExternaAsync(_codigoExterno.Trim());
        _mensajeCodigo = "✅ Código guardado. Sincronizando...";
        _codigoExterno = "";
        StateHasChanged();
        await Sync.SincronizarAsync();
        _mensajeCodigo = null;
    }

    private async Task RestablecerSync()
    {
        _restableciendo = true;
        StateHasChanged();
        try
        {
            await Sync.RestablecerTombstonesAsync();
            await Sync.SincronizarAsync();
        }
        finally { _restableciendo = false; }
    }
}
